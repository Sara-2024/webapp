{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-02-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "webapp-production",
      "database_id": "458ccf16-7417-45ec-931c-e1c51453c2cf"
    }
  ],
  // Twelve Data API Key (本番環境ではwrangler secret putで設定)
  "vars": {
    "TWELVE_DATA_API_KEY": ""
  }
}